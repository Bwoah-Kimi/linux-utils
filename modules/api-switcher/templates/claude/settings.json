{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "<fill-me: see provider_list.json>",
    "ANTHROPIC_BASE_URL": "<fill-me: see provider_list.json>",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(mkfs.*)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod 777 *)",
      "Bash(chown -R *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .)",
      "Bash(git branch -D *)",
      "Bash(shutdown *)",
      "Bash(reboot*)",
      "Bash(halt*)",
      "Bash(poweroff*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "<fill-me: path to your statusline script, e.g. bash ~/.claude/statusline-command.sh>"
  }
}
